rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function ownsArtistProfile(artistId) {
      return signedIn() && request.auth.uid == artistId;
    }

    function hasShowStatus(show) {
      return show.keys().hasAny(["status"]);
    }

    function isBookedShow(show) {
      return hasShowStatus(show) && show.status == "booked";
    }

    function isShowArtist(show) {
      return signedIn() &&
        show.keys().hasAny(["artists"]) &&
        show.artists is list &&
        show.artists.hasAny([request.auth.uid]);
    }

    function isEditableArtistShow(show) {
      return isShowArtist(show) &&
        hasShowStatus(show) &&
        (show.status == "proposed" || show.status == "archived");
    }

    match /admins/{adminId} {
      allow read: if ownsArtistProfile(adminId) || isAdmin();
      allow write: if isAdmin();
    }

    match /artists/{artistId} {
      allow read: if true;
      allow create, update: if ownsArtistProfile(artistId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /shows/{showId} {
      allow get: if isBookedShow(resource.data) || isEditableArtistShow(resource.data) || isAdmin();
      allow list: if signedIn() || isBookedShow(resource.data) || isAdmin();
      allow create: if isAdmin() || (
        isShowArtist(request.resource.data) &&
        hasShowStatus(request.resource.data) &&
        request.resource.data.status == "proposed"
      );
      allow update: if isAdmin() || (
        isShowArtist(resource.data) &&
        isShowArtist(request.resource.data) &&
        hasShowStatus(request.resource.data) &&
        (
          request.resource.data.status == "proposed" ||
          request.resource.data.status == "archived"
        )
      );
      allow delete: if isAdmin();
    }

    match /donors/{donorId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
