{
  "name": "phantom_reboot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "npm --prefix client run build",
    "emulators:start": "npx firebase-tools emulators:start --project demo-phantom-reboot --only auth,firestore,storage --import .firebase-data --export-on-exit .firebase-data",
    "emulators:seed": "npm --prefix client run seed:emulator",
    "heroku-postbuild": "npm install --prefix client --include=dev && npm --prefix client run build",
    "test": "npm run test:server && npm --prefix client test",
    "test:client": "npm --prefix client test",
    "test:server": "node --test test/*.test.js",
    "start": "node server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "supertest": "^7.1.4"
  }
}
